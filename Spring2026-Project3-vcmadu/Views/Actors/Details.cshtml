@model Spring2026_Project3_vcmadu.ViewModels.ActorDetailsViewModel
@{
    ViewData["Title"] = Model.Actor.Name;
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i> Back to Actors
    </a>
</div>

<div class="card mb-4">
    <div class="card-body d-flex gap-4 align-items-start">
        <div>
            @if (Model.Actor.Photo != null)
            {
                <img src="@Url.Action("Photo", "Actors", new { id = Model.Actor.Id })"
                     class="actor-photo" alt="@Model.Actor.Name" />
            }
            else
            {
                <i class="fas fa-user-circle fa-5x text-secondary"></i>
            }
        </div>
        <div>
            <h3>@Model.Actor.Name</h3>
            <p><strong>Gender:</strong> @Model.Actor.Gender</p>
            <p><strong>Age:</strong> @Model.Actor.Age</p>
            <p><strong>IMDB:</strong>
                <a href="@Model.Actor.ImdbLink" target="_blank" class="text-warning">
                    View on IMDB <i class="fas fa-external-link-alt"></i>
                </a>
            </p>
            @if (Model.MovieTitles.Any())
            {
                <p><strong>Movies:</strong> @string.Join(", ", Model.MovieTitles)</p>
            }
        </div>
    </div>
</div>

<!-- AI Tweets Section -->
<div class="card">
    <div class="card-header">
        <h4 class="mb-0"><i class="fab fa-twitter me-2"></i>AI-Generated Tweets & Sentiment</h4>
    </div>
    <div class="card-body">
        <div class="sentiment-heading">
            @Model.OverallSentiment
            <small class="text-muted ms-2">(Average Score: @Model.AverageCompoundScore.ToString("F3"))</small>
        </div>

        <table class="table table-striped datatable">
            <thead class="table-dark">
                <tr>
                    <th>Tweet</th>
                    <th>Sentiment</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tweet in Model.Tweets)
                {
                    <tr>
                        <td>@tweet.TweetText</td>
                        <td>
                            @{
                                var badgeClass = tweet.Sentiment == "Positive" ? "badge-positive"
                                               : tweet.Sentiment == "Negative" ? "badge-negative"
                                               : "badge-neutral";
                            }
                            <span class="badge @badgeClass px-2 py-1">
                                @tweet.Sentiment
                            </span>
                            <small class="text-muted ms-1">(@tweet.CompoundScore.ToString("F3"))</small>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>