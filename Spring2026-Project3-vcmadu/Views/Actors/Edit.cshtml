@model Spring2026_Project3_vcmadu.Models.Actor
@{
    ViewData["Title"] = "Edit Actor";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Actor</h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control bg-dark text-light border-secondary" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Gender" class="form-label"></label>
                        <select asp-for="Gender" class="form-select bg-dark text-light border-secondary">
                            <option value="">-- Select --</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Non-binary">Non-binary</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Age" class="form-label"></label>
                        <input asp-for="Age" type="number"
                               class="form-control bg-dark text-light border-secondary" />
                        <span asp-validation-for="Age" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ImdbLink" class="form-label">IMDB Link</label>
                        <input asp-for="ImdbLink" class="form-control bg-dark text-light border-secondary" />
                        <span asp-validation-for="ImdbLink" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Photo (leave blank to keep current)</label>
                        @if (Model.Photo != null)
                        {
                            <div class="mb-2">
                                <img src="@Url.Action("Photo", "Actors", new { id = Model.Id })"
                                     class="actor-photo" alt="Current photo" />
                            </div>
                        }
                        <input type="file" name="photoFile" accept="image/*"
                               class="form-control bg-dark text-light border-secondary" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}