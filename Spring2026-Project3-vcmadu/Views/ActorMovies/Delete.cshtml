@model Spring2026_Project3_vcmadu.Models.ActorMovie
@{
    ViewData["Title"] = "Delete Relationship";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="fas fa-trash me-2"></i>Delete Relationship</h4>
            </div>
            <div class="card-body">
                <p class="mb-3">Are you sure you want to remove this actor-movie relationship?</p>

                <dl class="row">
                    <dt class="col-sm-4">Actor</dt>
                    <dd class="col-sm-8">@Model.Actor.Name</dd>
                    <dt class="col-sm-4">Movie</dt>
                    <dd class="col-sm-8">@Model.Movie.Title</dd>
                </dl>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash me-1"></i> Yes, Delete
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>