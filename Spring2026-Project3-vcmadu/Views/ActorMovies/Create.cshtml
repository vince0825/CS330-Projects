@model Spring2026_Project3_vcmadu.Models.ActorMovie
@{
    ViewData["Title"] = "Add Relationship";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0"><i class="fas fa-link me-2"></i>Link Actor to Movie</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">Actor</label>
                        <select name="ActorId" asp-items="ViewBag.Actors"
                                class="form-select bg-dark text-light border-secondary">
                            <option value="">-- Select Actor --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Movie</label>
                        <select name="MovieId" asp-items="ViewBag.Movies"
                                class="form-select bg-dark text-light border-secondary">
                            <option value="">-- Select Movie --</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i> Save
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>