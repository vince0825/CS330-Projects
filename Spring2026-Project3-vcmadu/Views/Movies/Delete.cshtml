@model Spring2026_Project3_vcmadu.Models.Movie
@{
    ViewData["Title"] = "Delete Movie";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="fas fa-trash me-2"></i>Delete Movie</h4>
            </div>
            <div class="card-body">
                <p class="mb-3">Are you sure you want to delete this movie?
                   This will also remove all actor relationships.</p>

                <dl class="row">
                    <dt class="col-sm-4">Title</dt>
                    <dd class="col-sm-8">@Model.Title</dd>
                    <dt class="col-sm-4">Genre</dt>
                    <dd class="col-sm-8">@Model.Genre</dd>
                    <dt class="col-sm-4">Release Date</dt>
                    <dd class="col-sm-8">@Model.ReleaseDate.ToString("MMMM dd, yyyy")</dd>
                </dl>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash me-1"></i> Yes, Delete
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>