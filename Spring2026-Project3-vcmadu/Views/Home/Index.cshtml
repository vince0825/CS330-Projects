@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <h1 class="display-4 fw-bold" style="color: var(--primary)">🎬 CineBase</h1>
    <p class="lead text-muted">Your AI-powered movie & actor database</p>
    <hr class="my-4" style="border-color: #333;" />
    <div class="row justify-content-center g-4 mt-2">
        <div class="col-md-3">
            <div class="card h-100 text-center p-4">
                <i class="fas fa-film fa-3x mb-3" style="color: var(--primary)"></i>
                <h5>Movies</h5>
                <p class="text-muted small">Browse, add, and get AI-generated reviews</p>
                <a asp-controller="Movies" asp-action="Index" class="btn btn-primary mt-auto">
                    Go to Movies
                </a>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 text-center p-4">
                <i class="fas fa-user-circle fa-3x mb-3" style="color: var(--primary)"></i>
                <h5>Actors</h5>
                <p class="text-muted small">Manage actors and see AI-generated tweets</p>
                <a asp-controller="Actors" asp-action="Index" class="btn btn-primary mt-auto">
                    Go to Actors
                </a>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 text-center p-4">
                <i class="fas fa-link fa-3x mb-3" style="color: var(--primary)"></i>
                <h5>Relationships</h5>
                <p class="text-muted small">Link actors to movies</p>
                <a asp-controller="ActorMovies" asp-action="Index" class="btn btn-primary mt-auto">
                    Go to Relationships
                </a>
            </div>
        </div>
    </div>
</div>